            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Admin: unrestricted history (still read-only per python code) -->
        <record id="rule_allocation_history_admin_all" model="ir.rule">
            <field name="name">Allocation History: Admin unrestricted</field>
            <field name="model_id" ref="model_af_allocation_history"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
