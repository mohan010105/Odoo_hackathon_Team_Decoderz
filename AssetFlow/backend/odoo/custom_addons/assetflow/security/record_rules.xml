            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Manager: sees all allocations -->
        <record id="rule_asset_allocation_manager_all" model="ir.rule">
            <field name="name">Asset Allocation: Manager sees all allocations</field>
            <field name="model_id" ref="model_af_asset_allocation"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Admin: unrestricted allocations -->
        <record id="rule_asset_allocation_admin_all" model="ir.rule">
            <field name="name">Asset Allocation: Admin unrestricted</field>
            <field name="model_id" ref="model_af_asset_allocation"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- ============================================================
             Transfer Request Record Rules
             ============================================================ -->

        <!-- Employee: sees transfers where they are current or requested employee -->
        <record id="rule_transfer_request_employee_own" model="ir.rule">
            <field name="name">Transfer Request: Employee sees own transfers only</field>
            <field name="model_id" ref="model_af_transfer_request"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_employee'))]"/>
            <field name="domain_force">['|', ('current_holder_id.user_id', '=', user.id), ('requested_employee_id.user_id', '=', user.id)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Manager: sees all transfers -->
        <record id="rule_transfer_request_manager_all" model="ir.rule">
            <field name="name">Transfer Request: Manager sees all transfers</field>
            <field name="model_id" ref="model_af_transfer_request"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Admin: unrestricted transfers -->
        <record id="rule_transfer_request_admin_all" model="ir.rule">
            <field name="name">Transfer Request: Admin unrestricted</field>
            <field name="model_id" ref="model_af_transfer_request"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

