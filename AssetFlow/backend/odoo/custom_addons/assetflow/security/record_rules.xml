<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Asset Record Rules
             ============================================================ -->

        <!-- Employee: can only see assets assigned to them -->
        <record id="rule_asset_employee_own" model="ir.rule">
            <field name="name">Asset: Employee sees own assets only</field>
            <field name="model_id" ref="model_af_asset"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_employee'))]"/>
            <field name="domain_force">
                [('employee_id.user_id', '=', user.id)]
            </field>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Asset Manager: can see all assets (no restriction) -->
        <record id="rule_asset_manager_all" model="ir.rule">
            <field name="name">Asset: Manager sees all assets</field>
            <field name="model_id" ref="model_af_asset"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Admin: unrestricted -->
        <record id="rule_asset_admin_all" model="ir.rule">
            <field name="name">Asset: Admin unrestricted</field>
            <field name="model_id" ref="model_af_asset"/>
            <field name="groups" eval="[(4, ref('assetflow.group_assetflow_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- ============================================================
             Asset Allocation Record Rules
             ============================================================ -->

        <!-- Employee: own allocations only -->
        <record id="rule_asset_allocation_employee_own" model="ir.rule">
            <field name="name">Asset Allocation: Employee sees own allocations only</field>
            <field name="model_id" ref="model_af_asset_allocation"/>
