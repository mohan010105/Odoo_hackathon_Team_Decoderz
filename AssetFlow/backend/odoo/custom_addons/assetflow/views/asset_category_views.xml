<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             List View
             ============================================================ -->
        <record id="view_af_asset_category_list" model="ir.ui.view">
            <field name="name">af.asset.category.list</field>
            <field name="model">af.asset.category</field>
            <field name="arch" type="xml">
                <list string="Asset Categories" decoration-muted="status == 'inactive'">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="warranty_period" string="Warranty (months)"/>
                    <field name="asset_count" string="Assets"/>
                    <field name="status" widget="badge"
                        decoration-success="status == 'active'"
                        decoration-danger="status == 'inactive'"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             Form View
             ============================================================ -->
        <record id="view_af_asset_category_form" model="ir.ui.view">
            <field name="name">af.asset.category.form</field>
            <field name="model">af.asset.category</field>
            <field name="arch" type="xml">
                <form string="Asset Category">
                    <header>
                        <button name="action_activate" string="Activate"
                            type="object" class="oe_highlight"
                            invisible="status == 'active'"
                            groups="assetflow.group_assetflow_admin"/>
                        <button name="action_deactivate" string="Deactivate"
                            type="object" confirm="Deactivate this category?"
                            invisible="status == 'inactive'"
                            groups="assetflow.group_assetflow_admin"/>
                        <field name="status" widget="statusbar"
                            statusbar_visible="active,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_af_asset)d" type="action"
                                class="oe_stat_button" icon="fa-cube"
                                context="{'default_category_id': active_id}"
                                groups="assetflow.group_assetflow_manager">
                                <field name="asset_count" widget="statinfo" string="Assets"/>
                            </button>
                        </div>
                        <group>
                            <group string="Category Details">
                                <field name="name" placeholder="e.g. Laptops and Computers"/>
                                <field name="code" placeholder="e.g. COMP"/>
                                <field name="warranty_period"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" placeholder="Optional category description…"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================
             Search View
             ============================================================ -->
        <record id="view_af_asset_category_search" model="ir.ui.view">
            <field name="name">af.asset.category.search</field>
            <field name="model">af.asset.category</field>
            <field name="arch" type="xml">
                <search string="Search Categories">
                    <field name="name" string="Name"/>
                    <field name="code" string="Code"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('status','=','active')]"/>
                    <filter string="Inactive" name="inactive" domain="[('status','=','inactive')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             Window Action
             ============================================================ -->
        <record id="action_af_asset_category" model="ir.actions.act_window">
            <field name="name">Asset Categories</field>
            <field name="res_model">af.asset.category</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_af_asset_category_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first asset category
                </p>
                <p>Categories classify assets (e.g. Laptops, Furniture, Network Equipment).</p>
            </field>
        </record>

    </data>
</odoo>
