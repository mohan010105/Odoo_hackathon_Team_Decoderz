<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             List View
             ============================================================ -->
        <record id="view_af_asset_list" model="ir.ui.view">
            <field name="name">af.asset.list</field>
            <field name="model">af.asset</field>
            <field name="arch" type="xml">
                <list string="Assets"
                    decoration-muted="status == 'disposed'"
                    decoration-warning="status == 'under_maintenance'">
                    <field name="tag" string="Asset Tag"/>
                    <field name="name"/>
                    <field name="serial_number" optional="hide"/>
                    <field name="category_id"/>
                    <field name="department_id"/>
                    <field name="employee_id" string="Assigned To"/>
                    <field name="purchase_date" optional="hide"/>
                    <field name="purchase_cost" optional="hide" widget="monetary"/>
                    <field name="vendor" optional="hide"/>
                    <field name="condition" widget="badge"
                        decoration-success="condition == 'excellent'"
                        decoration-info="condition == 'good'"
                        decoration-warning="condition == 'fair'"
                        decoration-danger="condition == 'poor'"/>
                    <field name="status" widget="badge"
                        decoration-success="status == 'available'"
                        decoration-primary="status == 'allocated'"
                        decoration-warning="status == 'under_maintenance'"
                        decoration-danger="status == 'disposed'"/>
                    <field name="bookable" widget="boolean_toggle" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             Kanban View
             ============================================================ -->
        <record id="view_af_asset_kanban" model="ir.ui.view">
            <field name="name">af.asset.kanban</field>
            <field name="model">af.asset</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="tag"/>
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="department_id"/>
                    <field name="employee_id"/>
                    <field name="condition"/>
                    <field name="status"/>
                    <field name="bookable"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <small class="o_kanban_record_subtitle text-muted">
                                            <field name="tag"/>
                                        </small>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><field name="category_id"/></div>
                                    <div t-if="record.employee_id.value">
                                        Assigned: <field name="employee_id"/>
                                    </div>
                                    <div t-if="record.department_id.value">
                                        Dept: <field name="department_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="condition" widget="badge"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ============================================================
             Form View
             ============================================================ -->
        <record id="view_af_asset_form" model="ir.ui.view">
            <field name="name">af.asset.form</field>
            <field name="model">af.asset</field>
            <field name="arch" type="xml">
                <form string="Asset">
                    <header>
                        <button name="action_set_available" string="Set Available"
                            type="object" class="oe_highlight"
                            invisible="status == 'available' or status == 'disposed'"
                            groups="assetflow.group_assetflow_manager"/>
                        <button name="action_set_maintenance" string="Send to Maintenance"
                            type="object"
                            invisible="status == 'under_maintenance' or status == 'disposed'"
                            groups="assetflow.group_assetflow_manager"/>
                        <button name="action_dispose" string="Dispose Asset"
                            type="object"
                            confirm="This will mark the asset as disposed. Continue?"
                            invisible="status == 'disposed'"
                            groups="assetflow.group_assetflow_admin"/>
                        <field name="status" widget="statusbar"
                            statusbar_visible="available,allocated,under_maintenance,disposed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Asset Name"/>
                            </h1>
                            <div class="o_row">
                                <field name="tag" readonly="1" class="o_field_highlight"/>
                            </div>
                        </div>
                        <group>
                            <group string="Classification">
                                <field name="category_id"/>
                                <field name="serial_number" placeholder="e.g. SN-001"/>
                                <field name="vendor" placeholder="e.g. Dell Technologies"/>
                                <field name="bookable"/>
                            </group>
                            <group string="Ownership">
                                <field name="department_id"/>
                                <field name="employee_id"
                                    domain="[('department_id', '=', department_id), ('status', '=', 'active')]"/>
                                <field name="location" placeholder="e.g. IT Office - Desk 1"/>
                            </group>
                        </group>
                        <group>
                            <group string="Financial">
                                <field name="purchase_date"/>
                                <field name="purchase_cost" widget="monetary"/>
                                <field name="current_value" widget="monetary"/>
                            </group>
                            <group string="Condition">
                                <field name="condition"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"
                                placeholder="Optional notes about this asset…"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================
             Search View
             ============================================================ -->
        <record id="view_af_asset_search" model="ir.ui.view">
            <field name="name">af.asset.search</field>
            <field name="model">af.asset</field>
            <field name="arch" type="xml">
                <search string="Search Assets">
                    <field name="name" string="Asset Name"/>
                    <field name="tag" string="Asset Tag"/>
                    <field name="serial_number" string="Serial Number"/>
                    <field name="category_id" string="Category"/>
                    <field name="department_id" string="Department"/>
                    <field name="employee_id" string="Assigned To"/>
                    <field name="vendor" string="Vendor"/>
                    <separator/>
                    <filter string="Available" name="available" domain="[('status','=','available')]"/>
                    <filter string="Allocated" name="allocated" domain="[('status','=','allocated')]"/>
                    <filter string="In Maintenance" name="maintenance" domain="[('status','=','under_maintenance')]"/>
                    <filter string="Disposed" name="disposed" domain="[('status','=','disposed')]"/>
                    <separator/>
                    <filter string="Bookable" name="bookable" domain="[('bookable','=',True)]"/>
                    <separator/>
                    <filter string="Excellent Condition" name="excellent" domain="[('condition','=','excellent')]"/>
                    <filter string="Good Condition" name="good" domain="[('condition','=','good')]"/>
                    <filter string="Fair Condition" name="fair" domain="[('condition','=','fair')]"/>
                    <filter string="Poor Condition" name="poor" domain="[('condition','=','poor')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                        <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Condition" name="group_condition" context="{'group_by': 'condition'}"/>
                        <filter string="Vendor" name="group_vendor" context="{'group_by': 'vendor'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             Window Action
             ============================================================ -->
        <record id="action_af_asset" model="ir.actions.act_window">
            <field name="name">Assets</field>
            <field name="res_model">af.asset</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="search_view_id" ref="view_af_asset_search"/>
            <field name="context">{'search_default_available': 0}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Register your first asset
                </p>
                <p>Track company assets, allocate them to employees, and manage their full lifecycle.</p>
            </field>
        </record>

    </data>
</odoo>
