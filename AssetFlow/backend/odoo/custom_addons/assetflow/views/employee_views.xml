<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             List View
             ============================================================ -->
        <record id="view_af_employee_list" model="ir.ui.view">
            <field name="name">af.employee.list</field>
            <field name="model">af.employee</field>
            <field name="arch" type="xml">
                <list string="Employees"
                    decoration-muted="status == 'inactive'"
                    decoration-warning="status == 'on_leave'">
                    <field name="employee_id" string="ID"/>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="department_id"/>
                    <field name="role" widget="badge"
                        decoration-primary="role == 'admin'"
                        decoration-info="role == 'asset_manager'"
                        decoration-success="role == 'department_head'"/>
                    <field name="asset_count" string="Assets"/>
                    <field name="joining_date"/>
                    <field name="status" widget="badge"
                        decoration-success="status == 'active'"
                        decoration-warning="status == 'on_leave'"
                        decoration-danger="status == 'inactive'"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             Form View
             ============================================================ -->
        <record id="view_af_employee_form" model="ir.ui.view">
            <field name="name">af.employee.form</field>
            <field name="model">af.employee</field>
            <field name="arch" type="xml">
                <form string="Employee">
                    <header>
                        <button name="action_activate" string="Activate"
                            type="object" class="oe_highlight"
                            invisible="status == 'active'"
                            groups="assetflow.group_assetflow_admin"/>
                        <button name="action_deactivate" string="Deactivate"
                            type="object" confirm="Deactivate this employee?"
                            invisible="status == 'inactive'"
                            groups="assetflow.group_assetflow_admin"/>
                        <field name="status" widget="statusbar"
                            statusbar_visible="active,on_leave,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_af_asset)d" type="action"
                                class="oe_stat_button" icon="fa-cube"
                                context="{'default_employee_id': active_id}"
                                groups="assetflow.group_assetflow_manager">
                                <field name="asset_count" widget="statinfo" string="Assets"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Full Name"/>
                            </h1>
                            <field name="employee_id" readonly="1"/>
                        </div>
                        <group>
                            <group string="Employment Details">
                                <field name="department_id"/>
                                <field name="role"/>
                                <field name="joining_date"/>
                            </group>
                            <group string="Contact Information">
                                <field name="email" widget="email"/>
                                <field name="phone" widget="phone"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" placeholder="Optional notes about this employee…"/>
                        </group>
                        <notebook>
                            <page string="Assigned Assets" name="assets">
                                <field name="asset_ids" readonly="1">
                                    <list>
                                        <field name="tag"/>
                                        <field name="name"/>
                                        <field name="category_id"/>
                                        <field name="condition" widget="badge"
                                            decoration-success="condition == 'excellent'"
                                            decoration-info="condition == 'good'"
                                            decoration-warning="condition == 'fair'"
                                            decoration-danger="condition == 'poor'"/>
                                        <field name="status" widget="badge"
                                            decoration-success="status == 'available'"
                                            decoration-primary="status == 'allocated'"
                                            decoration-warning="status == 'under_maintenance'"
                                            decoration-danger="status == 'disposed'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================
             Search View
             ============================================================ -->
        <record id="view_af_employee_search" model="ir.ui.view">
            <field name="name">af.employee.search</field>
            <field name="model">af.employee</field>
            <field name="arch" type="xml">
                <search string="Search Employees">
                    <field name="name" string="Name"/>
                    <field name="employee_id" string="Employee ID"/>
                    <field name="email" string="Email"/>
                    <field name="department_id" string="Department"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('status','=','active')]"/>
                    <filter string="On Leave" name="on_leave" domain="[('status','=','on_leave')]"/>
                    <filter string="Inactive" name="inactive" domain="[('status','=','inactive')]"/>
                    <separator/>
                    <filter string="Admins" name="admin" domain="[('role','=','admin')]"/>
                    <filter string="Asset Managers" name="asset_manager" domain="[('role','=','asset_manager')]"/>
                    <filter string="Department Heads" name="dept_head" domain="[('role','=','department_head')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Role" name="group_role" context="{'group_by': 'role'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             Window Action
             ============================================================ -->
        <record id="action_af_employee" model="ir.actions.act_window">
            <field name="name">Employees</field>
            <field name="res_model">af.employee</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_af_employee_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Add your first employee
                </p>
                <p>Employees are linked to departments and assigned assets.</p>
            </field>
        </record>

    </data>
</odoo>
