<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             List View
             ============================================================ -->
        <record id="view_af_asset_allocation_list" model="ir.ui.view">
            <field name="name">af.asset.allocation.list</field>
            <field name="model">af.asset.allocation</field>
            <field name="arch" type="xml">
                <list string="Asset Allocations"
                    decoration-muted="status == 'cancelled'"
                    decoration-success="status == 'returned'"
                    decoration-primary="status == 'allocated'">
                    <field name="name" string="Allocation Number"/>
                    <field name="asset_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="allocation_date"/>
                    <field name="expected_return_date"/>
                    <field name="actual_return_date"/>
                    <field name="status" widget="badge"
                        decoration-info="status == 'draft'"
                        decoration-primary="status == 'allocated'"
                        decoration-success="status == 'returned'"
                        decoration-danger="status == 'cancelled'"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             Form View
             ============================================================ -->
        <record id="view_af_asset_allocation_form" model="ir.ui.view">
            <field name="name">af.asset.allocation.form</field>
            <field name="model">af.asset.allocation</field>
            <field name="arch" type="xml">
                <form string="Asset Allocation">
                    <header>
                        <button name="action_allocate" string="Allocate Asset"
                            type="object" class="oe_highlight"
                            invisible="status != 'draft'"
                            groups="assetflow.group_assetflow_manager"/>
                        <button name="action_return" string="Return Asset"
                            type="object" class="oe_highlight"
                            invisible="status != 'allocated'"
                            groups="assetflow.group_assetflow_manager"/>
                        <button name="action_cancel" string="Cancel Allocation"
                            type="object"
                            invisible="status not in ['draft', 'allocated']"
                            groups="assetflow.group_assetflow_manager"/>
                        <field name="status" widget="statusbar"
                            statusbar_visible="draft,allocated,returned,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Allocation Number"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Asset &amp; Duration">
                                <field name="asset_id" options="{'no_create': True}" readonly="status != 'draft'"/>
                                <field name="allocation_date" readonly="status != 'draft'"/>
                                <field name="expected_return_date" readonly="status != 'draft'"/>
                                <field name="actual_return_date" readonly="1" invisible="status != 'returned'"/>
                            </group>
                            <group string="Assignee Details">
                                <field name="employee_id" options="{'no_create': True}" readonly="status != 'draft'"/>
                                <field name="department_id" options="{'no_create': True}" readonly="status != 'draft'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Remarks" name="remarks">
                                <field name="remarks" placeholder="Add allocation remarks here..." readonly="status in ['returned', 'cancelled']"/>
                            </page>
                            <page string="Audit Info" name="audit_info" groups="assetflow.group_assetflow_manager">
                                <group>
                                    <field name="created_by"/>
                                    <field name="created_on"/>
                                    <field name="updated_on"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================
             Search View
             ============================================================ -->
        <record id="view_af_asset_allocation_search" model="ir.ui.view">
            <field name="name">af.asset.allocation.search</field>
            <field name="model">af.asset.allocation</field>
            <field name="arch" type="xml">
                <search string="Search Allocations">
                    <field name="name"/>
                    <field name="asset_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Allocated" name="allocated" domain="[('status', '=', 'allocated')]"/>
                    <filter string="Returned" name="returned" domain="[('status', '=', 'returned')]"/>
                    <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Asset" name="group_asset" context="{'group_by': 'asset_id'}"/>
                        <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                        <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             Window Action
             ============================================================ -->
        <record id="action_af_asset_allocation" model="ir.actions.act_window">
            <field name="name">Allocations</field>
            <field name="res_model">af.asset.allocation</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_af_asset_allocation_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new asset allocation
                </p>
                <p>Allocate available company assets to employees and track expected return dates.</p>
            </field>
        </record>

    </data>
</odoo>
