<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             Demo: Departments
             ============================================================ -->
        <record id="demo_dept_it" model="af.department">
            <field name="name">Information Technology</field>
            <field name="code">IT</field>
            <field name="description">Manages all technology infrastructure and systems</field>
            <field name="status">active</field>
        </record>

        <record id="demo_dept_hr" model="af.department">
            <field name="name">Human Resources</field>
            <field name="code">HR</field>
            <field name="description">Employee management, recruitment, and culture</field>
            <field name="status">active</field>
        </record>

        <record id="demo_dept_finance" model="af.department">
            <field name="name">Finance and Accounting</field>
            <field name="code">FIN</field>
            <field name="description">Financial planning, reporting, and compliance</field>
            <field name="status">active</field>
        </record>

        <record id="demo_dept_ops" model="af.department">
            <field name="name">Operations</field>
            <field name="code">OPS</field>
            <field name="description">Day-to-day business operations and logistics</field>
            <field name="status">active</field>
        </record>

        <record id="demo_dept_mkt" model="af.department">
            <field name="name">Marketing</field>
            <field name="code">MKT</field>
            <field name="description">Brand, digital marketing, and communications</field>
            <field name="status">active</field>
        </record>

        <!-- ============================================================
             Demo: Employees
             ============================================================ -->
        <record id="demo_emp_sarah" model="af.employee">
            <field name="name">Sarah Mitchell</field>
            <field name="email">sarah.mitchell@assetflow.demo</field>
            <field name="phone">+1-555-0101</field>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="role">admin</field>
            <field name="status">active</field>
            <field name="joining_date">2019-03-15</field>
        </record>

        <record id="demo_emp_james" model="af.employee">
            <field name="name">James Okafor</field>
            <field name="email">james.okafor@assetflow.demo</field>
            <field name="phone">+1-555-0102</field>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="role">asset_manager</field>
            <field name="status">active</field>
            <field name="joining_date">2020-07-22</field>
        </record>

        <record id="demo_emp_rachel" model="af.employee">
            <field name="name">Rachel Torres</field>
            <field name="email">rachel.torres@assetflow.demo</field>
            <field name="phone">+1-555-0105</field>
            <field name="department_id" ref="demo_dept_hr"/>
            <field name="role">department_head</field>
            <field name="status">active</field>
            <field name="joining_date">2018-11-05</field>
        </record>

        <record id="demo_emp_robert" model="af.employee">
            <field name="name">Robert Kim</field>
            <field name="email">robert.kim@assetflow.demo</field>
            <field name="phone">+1-555-0108</field>
            <field name="department_id" ref="demo_dept_finance"/>
            <field name="role">department_head</field>
            <field name="status">active</field>
            <field name="joining_date">2017-08-20</field>
        </record>

        <!-- Set department heads after employees are created -->
        <record id="demo_dept_hr" model="af.department">
            <field name="head_id" ref="demo_emp_rachel"/>
        </record>

        <record id="demo_dept_finance" model="af.department">
            <field name="head_id" ref="demo_emp_robert"/>
        </record>

        <!-- ============================================================
             Demo: Asset Categories
             ============================================================ -->
        <record id="demo_cat_computers" model="af.asset.category">
            <field name="name">Laptops and Computers</field>
            <field name="code">COMP</field>
            <field name="description">Desktop and laptop computers, workstations</field>
            <field name="warranty_period">36</field>
            <field name="status">active</field>
        </record>

        <record id="demo_cat_mobile" model="af.asset.category">
            <field name="name">Mobile Devices</field>
            <field name="code">MOB</field>
            <field name="description">Smartphones, tablets, and mobile accessories</field>
            <field name="warranty_period">24</field>
            <field name="status">active</field>
        </record>

        <record id="demo_cat_furniture" model="af.asset.category">
            <field name="name">Office Furniture</field>
            <field name="code">FURN</field>
            <field name="description">Desks, chairs, cabinets, and office furniture</field>
            <field name="warranty_period">60</field>
            <field name="status">active</field>
        </record>

        <record id="demo_cat_network" model="af.asset.category">
            <field name="name">Networking Equipment</field>
            <field name="code">NET</field>
            <field name="description">Routers, switches, access points, and network hardware</field>
            <field name="warranty_period">36</field>
            <field name="status">active</field>
        </record>

        <!-- ============================================================
             Demo: Assets
             ============================================================ -->
        <record id="demo_asset_dell_xps" model="af.asset">
            <field name="name">Dell XPS 15 Laptop</field>
            <field name="serial_number">SN-DX15-DEMO-001</field>
            <field name="category_id" ref="demo_cat_computers"/>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="employee_id" ref="demo_emp_sarah"/>
            <field name="purchase_date">2022-03-10</field>
            <field name="purchase_cost">1899.00</field>
            <field name="current_value">1400.00</field>
            <field name="vendor">Dell Technologies</field>
            <field name="condition">excellent</field>
            <field name="status">allocated</field>
            <field name="bookable" eval="False"/>
            <field name="location">IT Office - Desk 1</field>
        </record>

        <record id="demo_asset_macbook" model="af.asset">
            <field name="name">MacBook Pro 14 inch</field>
            <field name="serial_number">SN-MBP14-DEMO-002</field>
            <field name="category_id" ref="demo_cat_computers"/>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="employee_id" ref="demo_emp_james"/>
            <field name="purchase_date">2022-06-15</field>
            <field name="purchase_cost">2499.00</field>
            <field name="current_value">2000.00</field>
            <field name="vendor">Apple Inc.</field>
            <field name="condition">excellent</field>
            <field name="status">allocated</field>
            <field name="bookable" eval="False"/>
            <field name="location">IT Office - Desk 2</field>
        </record>

        <record id="demo_asset_iphone" model="af.asset">
            <field name="name">iPhone 14 Pro</field>
            <field name="serial_number">SN-IP14P-DEMO-003</field>
            <field name="category_id" ref="demo_cat_mobile"/>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="employee_id" ref="demo_emp_sarah"/>
            <field name="purchase_date">2023-01-15</field>
            <field name="purchase_cost">1199.00</field>
            <field name="current_value">1050.00</field>
            <field name="vendor">Apple Inc.</field>
            <field name="condition">excellent</field>
            <field name="status">allocated</field>
            <field name="bookable" eval="False"/>
            <field name="location">IT Admin</field>
        </record>

        <record id="demo_asset_spare_laptop" model="af.asset">
            <field name="name">HP EliteBook 840 (Spare)</field>
            <field name="serial_number">SN-HPE840-DEMO-004</field>
            <field name="category_id" ref="demo_cat_computers"/>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="purchase_date">2021-09-20</field>
            <field name="purchase_cost">1299.00</field>
            <field name="current_value">900.00</field>
            <field name="vendor">HP Inc.</field>
            <field name="condition">good</field>
            <field name="status">available</field>
            <field name="bookable" eval="True"/>
            <field name="location">IT Storage Room</field>
        </record>

        <record id="demo_asset_cisco_switch" model="af.asset">
            <field name="name">Cisco Catalyst 9300 Switch</field>
            <field name="serial_number">SN-CC9300-DEMO-005</field>
            <field name="category_id" ref="demo_cat_network"/>
            <field name="department_id" ref="demo_dept_it"/>
            <field name="purchase_date">2021-06-20</field>
