<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Scheduled Action: System Alert Scanner
             Runs daily to detect overdue returns, warranty expiry, etc.
             ============================================================ -->
        <record id="ir_cron_system_alert_scan" model="ir.cron">
            <field name="name">AssetFlow: System Alert Scanner</field>
            <field name="model_id" ref="model_af_system_alert"/>
            <field name="state">code</field>
            <field name="code">model.run_all_scans()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall">False</field>
        </record>

    </data>
</odoo>
